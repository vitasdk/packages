pkgname=cpython
pkgver=2.7
pkgrel=1
url="https://github.com/SonicMastr/cpython-vita"
source=("git+https://github.com/SonicMastr/cpython-vita.git")
sha256sums=('SKIP')
depends=('openssl libzip xz zlib bzip2')

build() {
  echo ""
}

package () {
  cd cpython-vita
  export CFLAGS="-std=gnu11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion -Wno-error=incompatible-pointer-types"
  export CXXFLAGS="-std=gnu++11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion -Wno-error=incompatible-pointer-types"
  sh build_vita.sh $pkgdir
  sh install_extra_modules.sh $pkgdir
  sh compile_modules_vita.sh $pkgdir
  rm -rf $pkgdir/$prefix/bin
  rm -rf $pkgdir/$prefix/share
}
