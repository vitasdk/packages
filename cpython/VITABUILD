pkgname=cpython
pkgver=2.7
pkgrel=1
url="https://github.com/SonicMastr/cpython-vita"
source=("git+https://github.com/SonicMastr/cpython-vita.git")
sha256sums=('SKIP')
depends=('openssl libzip xz zlib bzip2')

build() {
  echo ""
}

package () {
  cd cpython-vita
  sed -i 's/CFLAGS="/CFLAGS="-std=gnu11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion -Wno-error=incompatible-pointer-types /' build_vita.sh
  sed -i 's/CXXFLAGS="/CXXFLAGS="-std=gnu++11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion -Wno-error=incompatible-pointer-types /' build_vita.sh
  sed -i 's/LDFLAGS="/LDFLAGS="-lpthread /' build_vita.sh

  bash build_vita.sh $pkgdir
  bash install_extra_modules.sh $pkgdir

  bash compile_modules_vita.sh $pkgdir
  rm -rf $pkgdir/$prefix/bin
  rm -rf $pkgdir/$prefix/share
}
