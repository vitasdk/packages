build() {
  cd $pkgname
	cmake -S . -B build "-DCMAKE_TOOLCHAIN_FILE=${VITASDK}/share/vita.toolchain.cmake" -DCMAKE_BUILD_TYPE=Release
	cmake --build build
}

package () {
	cmake --build build --target install
}
