pkgname=libftpvita
pkgver=9999
pkgrel=1
url="https://github.com/xerpi/libftpvita"
source=("git+https://github.com/xerpi/libftpvita.git")
sha256sums=('SKIP')

build() {
  cd $pkgname/$pkgname
  make -j$(nproc) CFLAGS="$CFLAGS -std=gnu11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion"
}

package () {
  cd $pkgname/$pkgname
  make DESTDIR=$pkgdir install
}
