pkgname=lame
pkgver=3.100
pkgrel=1
url="https://lame.sourceforge.io/"
source=("svn://svn.code.sf.net/p/lame/svn/trunk/lame#revision=r6403")
sha256sums=('SKIP')

build() {
  cd lame
  ./configure --host=arm-vita-eabi --prefix=$prefix --disable-shared --enable-static --disable-frontend --disable-gtktest \
    CFLAGS="-std=gnu11 -Wl,-q -O2 -ftree-vectorize -mfpu=neon -fomit-frame-pointer -ffast-math -Wno-error=implicit-function-declaration -Wno-error=int-conversion"
  make -j$(nproc)
}

package () {
  cd lame
  make DESTDIR=$pkgdir install
}
