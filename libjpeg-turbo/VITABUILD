pkgname=libjpeg-turbo
pkgver=3.1.4
pkgrel=1
url="https://www.libjpeg-turbo.org/"
source=("https://github.com/libjpeg-turbo/libjpeg-turbo/releases/download/$pkgver/$pkgname-$pkgver.tar.gz")
sha256sums=('e23d3ebb2c6ee4d0e2a5823dbb55b614845df5ea3435c956fed5cf04041a87ad')

build() {
  cd $pkgname-$pkgver
  mkdir build && cd build
  cmake .. -DCMAKE_TOOLCHAIN_FILE=$VITASDK/share/vita.toolchain.cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$prefix -DENABLE_SHARED=FALSE -DWITH_SIMD=FALSE -DWITH_TOOLS=FALSE
  make -j$(nproc)
}

package() {
  cd $pkgname-$pkgver/build
  make DESTDIR=$pkgdir install
}
