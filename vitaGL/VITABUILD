pkgname=vitaGL
pkgver=9999
pkgrel=1
url="https://github.com/Rinnegatamante"
source=("git+https://github.com/Rinnegatamante/vitaGL.git")
sha256sums=('SKIP')
depends=('libmathneon vitaShaRK taihen SceShaccCgExt')

build() {
  cd $pkgname
  make HAVE_SBRK=1 NO_DEBUG=1 CFLAGS="-std=gnu11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion -Wno-error=incompatible-pointer-types" CXXFLAGS="-std=gnu++11 -Wno-error=implicit-function-declaration -Wno-error=int-conversion -Wno-error=incompatible-pointer-types" -j$(nproc)
}

package () {
  mkdir -p $pkgdir/$VITASDK/arm-vita-eabi/lib
  mkdir -p $pkgdir/$VITASDK/arm-vita-eabi/include
  
  cd $pkgname
  cp lib$pkgname.a $pkgdir/$VITASDK/arm-vita-eabi/lib/
  cp source/$pkgname.h $pkgdir/$VITASDK/arm-vita-eabi/include/
}
