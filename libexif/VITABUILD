pkgname=libexif
pkgver=0.6.26
pkgrel=1
url="https://libexif.github.io/"
source=("https://github.com/libexif/libexif/releases/download/v${pkgver}/libexif-${pkgver}.tar.xz")
sha256sums=('4a055ed6575e61ca46c3172be3c753cc16c9becd0f99ec71d58dd0e471476c0c')

build() {
  cd libexif-$pkgver
  ./configure --host=arm-vita-eabi --prefix=$prefix --disable-shared --enable-static
  make -j$(nproc)
}

package () {
  cd libexif-$pkgver
  make DESTDIR=$pkgdir install
}
